<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.github.jedwards1230.gofer</string>
	<key>ProgramArguments</key>
	<array>
		<string>/usr/local/bin/gofer</string>
		<string>daemon</string>
		<string>--listen</string>
		<string>127.0.0.1:7333</string>
		<string>--root</string>
		<string>/home/u/.gofer</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>StandardOutPath</key>
	<string>/home/u/.gofer/logs/daemon.out.log</string>
	<key>StandardErrorPath</key>
	<string>/home/u/.gofer/logs/daemon.err.log</string>
</dict>
</plist>
